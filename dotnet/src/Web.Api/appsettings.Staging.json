{
  "ConnectionStrings": {
    "SkuSync": ""
  },
  "DatabaseMigration": {
    "LockTimeoutSeconds": 120
  },
  "Skulabs": {
    "Api": {
      "BaseUrl": "https://api.skulabs.com",
      "ApiKey": ""
    },
    "Admin": {
      "BaseUrl": "https://app.skulabs.com",
      "Username": "",
      "Password": ""
    }
  },
  "Shopify": {
    "ShopUrl": "https://ivyandlavyboutique.myshopify.com",
    "ApiKey": ""
  },
  "Aws": {
    "Auth": {
      "AccessKey": "",
      "SecretKey": "",
      "Region": "us-east-1"
    },
    "Sqs": {
      "QueueUrl": "https://sqs.us-east-1.amazonaws.com/776952074202/staging-ivyandlavy-shop-events"
    }
  },
  "FeatureManagement": {
    "ShopifyWriteBack": false,
    "ShopifySyncEnabled": true,
    "SkulabsSyncEnabled": true,
    "SkulabsWriteBack": false
  },
  "ScheduledJobs": {
    "SkulabsItemSync": {
      "CronExpression": "0 0/10 * * * ?",
      "RunOnStart": true,
      "Enabled": true
    },
    "ProductMaintenance": {
      "CronExpression": "0 0 0 * * ?",
      "RunOnStart": true,
      "Enabled": true
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
        "Microsoft.AspNetCore.Routing.EndpointMiddleware": "Warning",
        "Serilog.AspNetCore.RequestLoggingMiddleware": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
