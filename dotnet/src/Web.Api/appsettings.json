{
  "ConnectionStrings": {
    "SkuSync": ""
  },
  "Skulabs": {
    "Api": {
      "BaseUrl": "https://api.skulabs.com",
      "ApiKey": ""
    },
    "Admin": {
      "BaseUrl": "https://app.skulabs.com",
      "Username": "",
      "Password": ""
    }
  },
  "Shopify": {
    "ShopUrl": "https://ivyandlavyboutique.myshopify.com",
    "ApiKey": ""
  },
  "Aws": {
    "Auth": {
      "AccessKey": "",
      "SecretKey": "",
      "Region": "us-east-1"
    },
    "Sqs": {
      "QueueUrl": "https://sqs.us-east-1.amazonaws.com/776952074202/shopify-shop-events"
    }
  },
  "FeatureManagement": {
    "ShopifyWriteBack": true
  },
  "ScheduledJobs": {
    "ShopifyProductSync": {
      "CronExpression": "0 0 0 * * ?",
      "RunOnStart": true,
      "Enabled": true
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
